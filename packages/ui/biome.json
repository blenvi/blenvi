{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"root": false,
	"extends": [
		"@blenvi/biome-config/base",
		"@blenvi/biome-config/react-internal"
	],
	"files": {
		"ignoreUnknown": true,
		"includes": ["**", "!node_modules", "!dist"]
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"linter": {
		"rules": {
			"suspicious": {
				"noUnknownAtRules": "off"
			}
		}
	}
}
